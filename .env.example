# Vinha D'Ouro — variáveis de ambiente
# Copia este ficheiro para .env e ajusta os valores ao teu ambiente local.
# O .env real está no .gitignore — nunca o commits.

# ── MySQL ─────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=vinhadouro

# ── Sessões ───────────────────────────────────────────────
# Tempo (em horas) que um token de sessão permanece válido após o login
SESSION_TTL_HOURS=8

# ── CORS ──────────────────────────────────────────────────
# Origens permitidas (separadas por vírgula). Mantém apenas localhost em dev.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
